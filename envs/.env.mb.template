# envs/envs.mb.template
# Template for Metabase environment variables to connect to PostgreSQL running on Windows 11

# --- METABASE CONNECTION TO WINDOWS's POSTGRES HOST ---
# 'host.docker.internal' allows the container to reach your Windows 11 PostgreSQL
MB_DB_TYPE=postgres
MB_DB_HOST=host.docker.internal
MB_DB_PORT=5432
MB_DB_DBNAME=metabase
MB_DB_USER=postgres
MB_DB_PASS=set_your_windows_pg_password_here

# --- METABASE SERVICE ---
# Port to access Metabase UI from the Windows browser
METABASE_UI_PORT=3000

# --- PERFORMANCE ---
# Recommended for local development to keep things snappy
JAVA_OPTS=-Xmx1g